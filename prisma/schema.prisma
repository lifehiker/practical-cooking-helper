generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SavedItemType: "EXTRACTED_RECIPE" | "MEAL_IDEA"
// UsageAction:   "SUGGESTION" | "EXTRACTION" | "SAVE"
// Plan:          "FREE" | "PRO_MONTHLY" | "PRO_YEARLY"

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String?
  image            String?
  role             String             @default("user")
  plan             String             @default("FREE")
  stripeCustomerId String?            @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lastLoginAt      DateTime?
  subscriptions    Subscription[]
  savedItems       SavedItem[]
  ingredientRuns   IngredientSearch[]
  recipeExtracts   RecipeExtract[]
  usageEvents      UsageEvent[]
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  status               String    @default("inactive")
  plan                 String    @default("FREE")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model SavedItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  summary     String?
  sourceUrl   String?
  imageUrl    String?
  searchText  String?
  payloadJson String
  createdAt   DateTime @default(now())

  @@index([userId, type, createdAt])
}

model IngredientSearch {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  identifier      String
  ingredientsJson String
  mustUseJson     String
  assumeBasics    Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([identifier, createdAt])
}

model RecipeExtract {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  identifier  String
  url         String
  title       String?
  payloadJson String
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([identifier, createdAt])
}

model UsageEvent {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  identifier String
  action     String
  metaJson   String?
  createdAt  DateTime @default(now())

  @@index([userId, action, createdAt])
  @@index([identifier, action, createdAt])
}
